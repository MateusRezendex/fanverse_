# Cenário A — backend rodando local + Postgres em Docker:
#   docker compose up -d postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sabor

# Cenário B — backend em container (docker compose --profile app up):
# o compose injeta DATABASE_URL automaticamente, este .env não é usado.

PORT=3000
CORS_ORIGIN=*

# --- Integração com WhatsApp ---------------------------------------------
# Default: desabilitado. Habilite e configure um provider para enviar mensagens.

WHATSAPP_ENABLED=false

# Provider: noop | cloudapi | zapi
WHATSAPP_PROVIDER=noop

# Segredo opcional para autenticar o webhook (envie em X-Webhook-Secret)
WHATSAPP_WEBHOOK_SECRET=

# --- Cloud API (Meta) ----------------------------------------------------
# Obtidos no Meta for Developers > seu app > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v18.0
# Token usado pela Meta na verificação do webhook (GET hub.verify_token)
WHATSAPP_VERIFY_TOKEN=

# --- Z-API ---------------------------------------------------------------
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
