# Variáveis usadas pelo docker-compose.yml.
# Copie para .env (na raiz) e ajuste se quiser sair do default.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sabor
POSTGRES_PORT=5432

BACKEND_PORT=3000
CORS_ORIGIN=*

# Integracao opcional com WhatsApp
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=noop
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_VERIFY_TOKEN=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
